        <div data-aos="fade-left">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c" alt="Bisnis sukses" class="rounded-3xl shadow-2xl" loading="lazy">
        </div>
    </div>
</section>

<!-- PRICING -->
<section id="harga" class="py-24 bg-emerald-50 dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="bg-white dark:bg-gray-900 rounded-3xl p-12 shadow-2xl">
