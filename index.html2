<!-- FOOTER -->
<footer class="bg-gray-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="text-lg">Hubungi kami: <strong>0818-1302-12</strong></p>
        <p class="text-xs text-gray-500 mt-8">© 2026 BizSkill Digital • Form Kontak aktif via Formspree</p>
    </div>
</footer>

<script>
    tailwind.config = { content: ["*"] };
    AOS.init({ once: true });

    // Countdown
    function countdown() {
        const end = new Date('2026-12-31T23:59:59').getTime();
        const el = document.getElementById('countdown');
        setInterval(() => {
            const diff = end - Date.now();
            if (diff < 0) return el.innerHTML = 'Diskon telah berakhir';
            const d = Math.floor(diff / 86400000);
            const h = Math.floor((diff % 86400000) / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            el.innerHTML = `${d} hari ${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}`;
        }, 1000);
    }
    window.onload = countdown;
</script>
</body>
</html>