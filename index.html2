<!-- FORM KONTAK BARU -->
<section id="kontak" class="py-24 bg-gray-100 dark:bg-gray-800">
    <div class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-12" data-aos="fade-up">
            <h2 class="text-4xl font-bold">Hubungi Kami atau Dapatkan Checklist Gratis</h2>
            <p class="mt-4 text-gray-600 dark:text-gray-400">Isi form di bawah ini. Kami akan balas dalam 24 jam + kirim Checklist 7 Skill Bisnis gratis!</p>
        </div>
        
        <form action="https://formspree.io/f/https://formspree.io/f/xkoqayvj method="POST" class="space-y-6">
            <div>
                <input type="text" name="nama" placeholder="Nama Lengkap" required 
                       class="w-full px-6 py-5 border border-gray-300 dark:border-gray-700 rounded-3xl focus:outline-none focus:border-emerald-500">
            </div>
            <div>
                <input type="email" name="email" placeholder="Email kamu" required 
                       class="w-full px-6 py-5 border border-gray-300 dark:border-gray-700 rounded-3xl focus:outline-none focus:border-emerald-500">
            </div>
            <div>
                <textarea name="pesan" rows="4" placeholder="Pesan / Pertanyaan (opsional)" 
                          class="w-full px-6 py-5 border border-gray-300 dark:border-gray-700 rounded-3xl focus:outline-none focus:border-emerald-500"></textarea>
